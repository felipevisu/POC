<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.9.xsd">

    <!-- Schema + webuser bootstrapped manually via db/create.sql (root-only DDL). -->
    <changeSet id="1-create-tables" author="felipe">
        <sqlFile path="create-tables.sql" relativeToChangelogFile="true"
                 splitStatements="true" stripComments="true" endDelimiter=";"/>
    </changeSet>

    <changeSet id="2-seed-profiles" author="felipe">
        <sqlFile path="seed-profiles.sql" relativeToChangelogFile="true"
                 splitStatements="true" stripComments="true" endDelimiter=";"/>
    </changeSet>

</databaseChangeLog>